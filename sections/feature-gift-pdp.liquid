{% comment %}
  Section: Features Grid
  Style: Image + Heading + Description cards (dark navy bg or light bg)
  Layout: 2x3 or 3x2 grid, fully customizable
{% endcomment %}

{{ 'features-grid.css' | asset_url | stylesheet_tag }}

<section
  class="features-grid"
  id="features-grid-{{ section.id }}"
  style="
    --fg-bg: {{ section.settings.bg_color }};
    --fg-text: {{ section.settings.text_color }};
    --fg-desc-color: {{ section.settings.desc_color }};
    --fg-heading-size: {{ section.settings.heading_font_size }}px;
    --fg-desc-size: {{ section.settings.desc_font_size }}px;
    --fg-img-size: {{ section.settings.image_size }}px;
    --fg-img-radius: {{ section.settings.image_radius }}%;
    --fg-card-bg: {{ section.settings.card_bg_color }};
    --fg-card-radius: {{ section.settings.card_radius }}px;
    --fg-card-padding: {{ section.settings.card_padding }}px;
    --fg-gap: {{ section.settings.grid_gap }}px;
    --fg-cols: {{ section.settings.columns }};
    --fg-section-padding-top: {{ section.settings.padding_top }}px;
    --fg-section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="features-grid__container">

    {% if section.settings.section_heading != blank or section.settings.section_subheading != blank %}
      <div class="features-grid__header">
        {% if section.settings.section_heading != blank %}
          <h2 class="features-grid__section-title">{{ section.settings.section_heading }}</h2>
        {% endif %}
        {% if section.settings.section_subheading != blank %}
          <p class="features-grid__section-sub">{{ section.settings.section_subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="features-grid__grid">
      {% for block in section.blocks %}
        <div
          class="features-grid__card {% if section.settings.card_style == 'boxed' %}features-grid__card--boxed{% endif %}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            <div class="features-grid__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                width="{{ section.settings.image_size }}"
                height="{{ section.settings.image_size }}"
                loading="lazy"
              >
            </div>
          {% elsif block.settings.icon_emoji != blank %}
            <div class="features-grid__img-wrap features-grid__img-wrap--emoji">
              <span>{{ block.settings.icon_emoji }}</span>
            </div>
          {% endif %}

          <div class="features-grid__card-body">
            {% if block.settings.heading != blank %}
              <h3 class="features-grid__heading">{{ block.settings.heading }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="features-grid__desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  #features-grid-{{ section.id }} {
    background-color: var(--fg-bg);
    padding-top: var(--fg-section-padding-top);
    padding-bottom: var(--fg-section-padding-bottom);
  }

  #features-grid-{{ section.id }} .features-grid__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #features-grid-{{ section.id }} .features-grid__header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  #features-grid-{{ section.id }} .features-grid__section-title {
    color: var(--fg-text);
    font-size: clamp(24px, 3vw, {{ section.settings.section_heading_size }}px);
    font-weight: 700;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  #features-grid-{{ section.id }} .features-grid__section-sub {
    color: var(--fg-desc-color);
    font-size: {{ section.settings.desc_font_size }}px;
    margin: 0;
    max-width: 600px;
    {% if section.settings.header_align == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  #features-grid-{{ section.id }} .features-grid__grid {
    display: grid;
    grid-template-columns: repeat(var(--fg-cols), 1fr);
    gap: var(--fg-gap);
  }

  #features-grid-{{ section.id }} .features-grid__card {
    display: flex;
    flex-direction: {{ section.settings.card_layout }};
    align-items: {% if section.settings.card_layout == 'row' %}center{% else %}flex-start{% endif %};
    gap: {% if section.settings.card_layout == 'row' %}16px{% else %}{{ section.settings.card_inner_gap }}px{% endif %};
  }

  #features-grid-{{ section.id }} .features-grid__card--boxed {
    background: var(--fg-card-bg);
    border-radius: var(--fg-card-radius);
    padding: var(--fg-card-padding);
  }

  #features-grid-{{ section.id }} .features-grid__img-wrap {
    flex-shrink: 0;
    width: var(--fg-img-size);
    height: var(--fg-img-size);
    border-radius: var(--fg-img-radius);
    overflow: hidden;
  }

  #features-grid-{{ section.id }} .features-grid__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #features-grid-{{ section.id }} .features-grid__img-wrap--emoji {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.08);
    font-size: calc(var(--fg-img-size) * 0.5);
  }

  #features-grid-{{ section.id }} .features-grid__card-body {
    flex: 1;
  }

  #features-grid-{{ section.id }} .features-grid__heading {
    color: var(--fg-text);
    font-size: var(--fg-heading-size);
    font-weight: 600;
    margin: 0 0 10px;
    line-height: 1.25;
  }

  #features-grid-{{ section.id }} .features-grid__desc {
    color: var(--fg-desc-color);
    font-size: var(--fg-desc-size);
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    #features-grid-{{ section.id }} .features-grid__grid {
      grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
      gap: {{ section.settings.mobile_gap }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Features Grid",
  "tag": "section",
  "class": "features-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "textarea",
      "id": "section_subheading",
      "label": "Section Subheading"
    },
    {
      "type": "range",
      "id": "section_heading_size",
      "label": "Section Heading Size (px)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 40
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Space below header (px)",
      "min": 16,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Columns (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile Grid Gap (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max Container Width (px)",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1200
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "flat", "label": "Flat (no box)" },
        { "value": "boxed", "label": "Boxed (with background)" }
      ],
      "default": "flat"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card Layout",
      "options": [
        { "value": "column", "label": "Stacked (image on top)" },
        { "value": "row", "label": "Side by side (image left)" }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "card_inner_gap",
      "label": "Space between image & text (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 20
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background (boxed only)",
      "default": "#1a2c4e"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Padding (px)",
      "min": 12,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Image / Icon"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image Size (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image Border Radius (%)",
      "info": "0 = square, 50 = circle",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 50
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Card Heading Size (px)",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "desc_font_size",
      "label": "Description Size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#c9d4d4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#3a3a4a"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji Icon (fallback if no image)",
          "info": "Used only if no image is selected. e.g. ✦ ✿ ◈"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description that explains this feature or quality in plain language."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "heading": "The best cotton. Period.",
            "description": "Only extra-long staple cotton. Suvin, Supima, and other premium varieties. Picked for softness and built to last."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "heading": "Custom-made fabrics.",
            "description": "Every fabric is knit, dyed, and finished exclusively for us. Nothing off the shelf, no shortcuts."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "heading": "Engineered for perfect fit.",
            "description": "Fits are developed with digital simulations for stretch, tension, and drape. Patterns refined per size."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "heading": "Tested to last.",
            "description": "Pilling, wash cycles, spirality, long-term wear. Every product is put through it before it ships."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "heading": "No logos. Ever.",
            "description": "You won't find our name on the outside. The fabric, the fit, how it wears over time — that's the branding."
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "heading": "Safe. Certified.",
            "description": "Safe for all skin types, including children. Tested in certified labs and compliant with ASTM and OEKO-TEX® standards."
          }
        }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
