{% schema %}
{
  "name": "About Us — Fan Cards",
  "tag": "section",
  "class": "wau-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "ABOUT US"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Description",
      "default": "Be bold, be you. Born from a belief that every woman deserves confidence in everything she wears — our products are crafted with care, purpose, and a fearless spirit."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0C4168"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#21F010"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 160, "step": 4, "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Image Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "card_label",
          "label": "Caption (optional)",
          "default": "Our Style"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat Pill",
      "settings": [
        {
          "type": "text",
          "id": "stat_value",
          "label": "Value",
          "default": "10K+"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Label",
          "default": "Happy Customers"
        }
      ]
    },
    {
      "type": "ticker",
      "name": "Ticker Phrase",
      "settings": [
        {
          "type": "text",
          "id": "ticker_text",
          "label": "Phrase",
          "default": "WE ARE BOLD"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us — Fan Cards",
      "blocks": [
        { "type": "card", "settings": { "card_label": "Pure Confidence" } },
        { "type": "card", "settings": { "card_label": "Born Bold" } },
        { "type": "card", "settings": { "card_label": "Fearless Spirit" } },
        { "type": "stat", "settings": { "stat_value": "10K+", "stat_label": "Happy Customers" } },
        { "type": "stat", "settings": { "stat_value": "4.9★", "stat_label": "Avg. Rating" } },
        { "type": "stat", "settings": { "stat_value": "100%", "stat_label": "Made with Love" } },
        { "type": "ticker", "settings": { "ticker_text": "WE ARE BOLD" } },
        { "type": "ticker", "settings": { "ticker_text": "WE ARE STRONG" } },
        { "type": "ticker", "settings": { "ticker_text": "WE ARE FEARLESS" } },
        { "type": "ticker", "settings": { "ticker_text": "WE ARE CONFIDENT" } },
        { "type": "ticker", "settings": { "ticker_text": "WE ARE BEAUTIFUL" } }
      ]
    }
  ]
}
{% endschema %}
