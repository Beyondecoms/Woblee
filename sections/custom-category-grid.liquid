/* MOBILE */
@media screen and (max-width: 749px){



  .shop-desk{
    display:none !important;
  }

  .shop-mobile{
    display:block;
    padding:20px 15px;
  }

  .shop-mobile-track{
    display:flex;
    gap:12px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    padding-bottom:8px;
  }

  .shop-mobile-track::-webkit-scrollbar{
    display:none;
  }

  .shop-mobile-slide{
    flex:0 0 85%;
    scroll-snap-align:start;
    overflow:hidden;
    position:relative;
  }

  .shop-mobile-slide img{
    width:100%;
    height:320px;
    object-fit: fill;
    display:block;

  }

  .shop-mobile-dots{
    display:flex;
    justify-content:center;
    gap:8px;
    margin-top:12px;
  }

  .shop-mobile-dot{
    width:8px;
    height:8px;
    background:#d9d9d9;
    transition:all .25s ease;
  }

  .shop-mobile-dot.is-active{
    width:24px;
    background:#8f8f8f;
  }
  .t4s-container-fluid{
  padding: 0 !important;
}
}

