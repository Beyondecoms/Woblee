{% comment %}
  Editorial Collection Grid Section - Optimized for Page Speed
  - Responsive images with srcset & sizes
  - Priority hints (eager for first image)
  - Reduced CSS repaints
{% endcomment %}

<section class="ecg-section" id="ecg-{{ section.id }}">
  <div class="ecg-grid">
    {% for block in section.blocks %}

      <div class="ecg-item" {{ block.shopify_attributes }}>
        <a class="ecg-image-wrap" href="{{ block.settings.button_1_url | default: block.settings.button_2_url | default: '#' }}">
          {% if block.settings.image != blank %}
            {% assign image = block.settings.image %}
            {% assign widths = '400,600,800,1000' | split: ',' %}
            {% assign srcset_parts = '' %}
            {% for w in widths %}
              {% assign url = image | image_url: width: w %}
              {% assign srcset_parts = srcset_parts | append: url | append: ' ' | append: w | append: 'w' %}
              {% unless forloop.last %}{% assign srcset_parts = srcset_parts | append: ', ' %}{% endunless %}
            {% endfor %}
            <img
              src="{{ image | image_url: width: 600 }}"
              srcset="{{ srcset_parts }}"
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 50vw, 25vw"
              alt="{{ block.settings.heading | escape }}"
              class="ecg-img"
         
        
                loading="lazy"
          
              decoding="async"
            >
          {% else %}
            <div class="ecg-placeholder">
              {{ 'image' | placeholder_svg_tag: 'ecg-placeholder-svg' }}
            </div>
          {% endif %}
        </a>

        <div class="ecg-content">
          {% if block.settings.heading != blank %}
            <p class="ecg-heading">{{ block.settings.heading }}</p>
          {% endif %}

          <div class="ecg-buttons">
            {% if block.settings.button_1_label != blank %}
              <a href="{{ block.settings.button_1_url | default: '#' }}" class="ecg-btn">
                {{ block.settings.button_1_label }}
              </a>
            {% endif %}
            {% if block.settings.button_2_label != blank %}
              <a href="{{ block.settings.button_2_url | default: '#' }}" class="ecg-btn">
                {{ block.settings.button_2_label }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
#ecg-{{ section.id }} {
  --brand-blue: #0C4168;
  --brand-lime: #21F010;
  --brand-white: #FFFFFF;
  --brand-grey: #626261;
  --brand-burgundy: #851828;

  --ecg-bg: var(--brand-white);
  --ecg-heading-color: var(--brand-blue);
  --ecg-btn-color: var(--brand-blue);
  --ecg-btn-hover: var(--brand-lime);

  --ecg-padding-top: {{ section.settings.padding_top }}px;
  --ecg-padding-bottom: {{ section.settings.padding_bottom }}px;
  --ecg-img-ratio: {{ section.settings.image_ratio }};
  --ecg-max-width: {{ section.settings.max_width }}px;
  --ecg-horizontal-padding: {{ section.settings.section_padding_horizontal }}px;
}

.ecg-section {
  background: var(--ecg-bg);
  padding: var(--ecg-padding-top) 0 var(--ecg-padding-bottom);
  font-family: Aptos, Arial, Helvetica, sans-serif;
}

.ecg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(12px, 1.2vw, 24px);
  max-width: var(--ecg-max-width);
  margin: 0 auto;
  padding: 0 var(--ecg-horizontal-padding);
}

.ecg-item {
  display: flex;
  flex-direction: column;
  background: #fff;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(12, 65, 104, 0.08);
  transition: transform 0.35s ease, box-shadow 0.35s ease;
  contain: layout paint; /* Improves rendering performance */
}

.ecg-item:hover {
  transform: translateY(-6px);
  box-shadow: 0 18px 42px rgba(12, 65, 104, 0.14);
}

.ecg-image-wrap {
  display: block;
  overflow: hidden;
  aspect-ratio: var(--ecg-img-ratio);
  background: #f3f3f3;
  position: relative;
}

.ecg-image-wrap::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.02) 0%,
    rgba(0, 0, 0, 0) 45%,
    rgba(12, 65, 104, 0.10) 100%
  );
  opacity: 0;
  transition: opacity 0.35s ease;
  pointer-events: none;
}

.ecg-item:hover .ecg-image-wrap::after {
  opacity: 1;
}

.ecg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.65s ease;
}

.ecg-image-wrap:hover .ecg-img {
  transform: scale(1.08);
}

.ecg-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f1f4f7, #e6ebf0);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ecg-placeholder-svg {
  width: 60px;
  height: 60px;
  opacity: 0.35;
}

.ecg-content {
  padding: 16px 14px 18px;
  position: relative;
}

.ecg-content::before {
  content: "";
  display: block;
  width: 46px;
  height: 3px;
  background: var(--brand-lime);
  margin-bottom: 12px;
  transition: width 0.35s ease, background 0.35s ease;
}

.ecg-item:hover .ecg-content::before {
  width: 68px;
  background: var(--brand-blue);
}

.ecg-heading {
  font-family: Helvetica, Arial, sans-serif;
  font-size: clamp(18px, 1.7vw, 28px);
  font-weight: 800;
  line-height: 1.05;
  color: var(--ecg-heading-color);
  margin: 0 0 10px;
  letter-spacing: -0.02em;
  text-transform: none;
  transition: transform 0.35s ease, color 0.35s ease;
}

.ecg-item:hover .ecg-heading {
  transform: translateY(-1px);
  color: #0a3557;
}

.ecg-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.ecg-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 0;
  font-family: Aptos, Arial, Helvetica, sans-serif;
  font-size: clamp(12px, 1vw, 14px);
  font-weight: 800;
  color: var(--ecg-btn-color);
  text-decoration: none;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: transform 0.25s ease, color 0.25s ease, opacity 0.25s ease;
  line-height: 1.2;
  position: relative;
}

.ecg-btn::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 6px;
  width: 100%;
  height: 2px;
  background: currentColor;
  transform: scaleX(1);
  transform-origin: left;
  transition: transform 0.28s ease, background 0.28s ease;
}

.ecg-btn:hover {
  color: var(--ecg-btn-hover);
  transform: translateY(-1px);
}

.ecg-btn:hover::after {
  transform: scaleX(0.65);
  background: var(--ecg-btn-hover);
}

.ecg-btn:focus-visible,
.ecg-image-wrap:focus-visible {
  outline: 2px solid var(--brand-blue);
  outline-offset: 3px;
}

/* Tablet */
@media (max-width: 1024px) {
  .ecg-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile */
@media (max-width: 640px) {
  .ecg-grid {
    gap: 16px;
    padding: 0 16px;
  }

  .ecg-content {
    padding: 14px 12px 16px;
  }

  .ecg-heading {
    font-size: 18px;
    line-height: 1.12;
  }

  .ecg-btn {
    font-size: 12px;
    padding: 8px 0;
  }
}

/* Small mobile polish */
@media (max-width: 480px) {
  .ecg-section {
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .ecg-content::before {
    width: 36px;
    margin-bottom: 10px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Editorial",
  "tag": "section",
  "class": "editorial-collection-grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max section width (px)",
      "min": 800,
      "max": 1600,
      "step": 20,
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section top padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section bottom padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "2/3", "label": "Tall Portrait (2:3)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "4/5", "label": "Portrait (4:5)" }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button / link color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "heading_font",
      "label": "Heading font name",
      "default": "Garamond"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (px)",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "text",
      "id": "button_font",
      "label": "Button font name",
      "default": "Helvetica Neue"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button font size (px)",
      "min": 9,
      "max": 18,
      "step": 1,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Linen Shop"
        },
        {
          "type": "header",
          "content": "Button 1 (e.g. Women / Shop Now)"
        },
        {
          "type": "text",
          "id": "button_1_label",
          "label": "Button 1 label",
          "default": "Women",
          "info": "Leave blank to hide this button"
        },
        {
          "type": "url",
          "id": "button_1_url",
          "label": "Button 1 link"
        },
        {
          "type": "header",
          "content": "Button 2 (e.g. Men — optional)"
        },
        {
          "type": "text",
          "id": "button_2_label",
          "label": "Button 2 label",
          "info": "Leave blank to hide this button. Fill both for two links."
        },
        {
          "type": "url",
          "id": "button_2_url",
          "label": "Button 2 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Editorial",
      "blocks": [
        {
          "type": "collection_item",
          "settings": {
            "heading": "The Linen Shop",
            "button_1_label": "Women",
            "button_2_label": "Men"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "heading": "The Getaway Edit",
            "button_1_label": "Women",
            "button_2_label": "Men"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "heading": "Dresses",
            "button_1_label": "Shop Now"
          }
        },
        {
          "type": "collection_item",
          "settings": {
            "heading": "Matching Sets",
            "button_1_label": "Shop Now"
          }
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}