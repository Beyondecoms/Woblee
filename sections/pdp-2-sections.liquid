<section
  class="feature-showcase"
  style="
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  "
>
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <div class="feature-showcase__header">
        <h2
          class="feature-showcase__heading"
          style="
            color: {{ section.settings.heading_color }};
            font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
          "
        >
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <div class="feature-showcase__slider splide">
      <div class="splide__track">
        <div class="splide__list">

          {% for block in section.blocks %}
            <div
              class="splide__slide"
              {{ block.shopify_attributes }}
            >
              <div
                class="feature-card feature-card--{{ section.settings.layout_style }}"
                style="
                  background: {{ block.settings.card_bg }};
                  text-align: {{ block.settings.content_alignment }};
                "
              >

                {% if block.settings.image != blank %}
                  <div
                    class="feature-card__image-wrapper"
                    {% if section.settings.layout_style == 'feature' %}
                      style="max-width: {{ block.settings.image_width }}px;"
                    {% endif %}
                  >
                    {{
                      block.settings.image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        class: 'feature-card__image'
                    }}
                  </div>
                {% endif %}

                <div class="feature-card__content">

                  {% if block.settings.title != blank %}
                    <h3
                      class="feature-card__title"
                      style="
                        color: {{ block.settings.title_color }};
                      "
                    >
                      {{ block.settings.title }}
                    </h3>
                  {% endif %}

                  {% if block.settings.description != blank %}
                    <div
                      class="feature-card__description"
                      style="
                        color: {{ block.settings.description_color }};
                      "
                    >
                      {{ block.settings.description }}
                    </div>
                  {% endif %}

                  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                    <a
                      href="{{ block.settings.button_link }}"
                      class="feature-card__button"
                      style="
                        background: {{ block.settings.button_bg }};
                        color: {{ block.settings.button_text_color }};
                      "
                    >
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}

                </div>

              </div>
            </div>
          {% endfor %}

        </div>
      </div>

      {% if section.settings.show_arrows %}
        <div class="splide__arrows">
          <button class="splide__arrow splide__arrow--prev">
            ←
          </button>

          <button class="splide__arrow splide__arrow--next">
            →
          </button>
        </div>
      {% endif %}

    </div>

  </div>
</section>

{%  style %} 
.feature-showcase {
  overflow: hidden;
}

.feature-showcase .page-width {
  max-width: 1600px;
  margin: 0 auto;
}

.feature-showcase__header {
  margin-bottom: 40px;
}

.feature-showcase__heading {
  margin: 0;
  line-height: 1.2;
  font-size: {{ section.settings.heading_size_desktop }}px;
}

.feature-showcase__slider {
  position: relative;
}

.feature-card {
  height: 100%;
  transition: all .35s ease;
}

.feature-card:hover {
  transform: translateY(-4px);
}

.feature-card__image-wrapper {
  overflow: hidden;
}

.feature-card__image {
  width: 100%;
  display: block;
  transition: transform .5s ease;
}

.feature-card:hover .feature-card__image {
  transform: scale(1.04);
}

.feature-card__title {
  margin: 0 0 15px;
  font-size: var(--title-size-desktop);
  line-height: 1.2;
}

.feature-card__description {
  margin-bottom: 20px;
  line-height: 1.6;
  font-size: var(--desc-size-desktop);
}

.feature-card__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  padding: 12px 24px;
  border: 1px solid currentColor;
  transition: .3s ease;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.feature-card__button:hover {
  opacity: .85;
}

/* -----------------------
   CARD LAYOUT
------------------------ */

.feature-card--card .feature-card__image-wrapper {
  margin-bottom: 20px;
}

.feature-card--card .feature-card__image {
  aspect-ratio: 4/4;
  object-fit: cover;
}

.feature-card--card .feature-card__content {
  padding: 0;
}

/* -----------------------
   FEATURE LAYOUT
------------------------ */

.feature-card--feature {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  padding: 25px;
}

.feature-card--feature .feature-card__image-wrapper {
  flex-shrink: 0;
}

.feature-card--feature .feature-card__image {
  width: 100%;
  height: auto;
  object-fit: cover;
}

.feature-card--feature .feature-card__content {
  flex: 1;
}

/* -----------------------
   SPLIDE ARROWS
------------------------ */

.feature-showcase .splide__arrows {
  position: absolute;
  top: -70px;
  right: 0;
  display: flex;
  gap: 10px;
}

.feature-showcase .splide__arrow {
  position: static;
  transform: none;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 1px solid #ddd;
  background: #fff;
  cursor: pointer;
  opacity: 1;
}

.feature-showcase .splide__arrow svg {
  fill: #000;
}

.feature-showcase .splide__pagination {
  margin-top: 25px;
  position: static;
}

.feature-showcase .splide__pagination__page.is-active {
  transform: scale(1.2);
}

/* -----------------------
   RESPONSIVE
------------------------ */

@media screen and (max-width: 767px) {

  .feature-showcase__heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
  }

  .feature-card--feature {
    flex-direction: column;
    padding: 15px;
  }

  .feature-card__title {
    font-size: var(--title-size-mobile);
  }

  .feature-card__description {
    font-size: var(--desc-size-mobile);
  }

  .feature-showcase .splide__arrows {
    top: -55px;
  }

  .feature-showcase .splide__arrow {
    width: 40px;
    height: 40px;
  }
}
{% endstyle %}

<script>
    document.addEventListener('DOMContentLoaded', function () {

  const sliders = document.querySelectorAll('.feature-showcase__slider');

  sliders.forEach((slider) => {

    new Splide(slider, {
      type: 'slide',
      perPage: 3,
      perMove: 1,
      gap: '{{ section.settings.card_gap }}px',
      arrows: {{ section.settings.show_arrows }},
      pagination: {{ section.settings.show_dots }},
      drag: true,
      rewind: true,

      breakpoints: {
        1200: {
          perPage: 2
        },

        767: {
          perPage: 1
        }
      }
    }).mount();

  });

});
</script>

