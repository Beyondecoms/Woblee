{% liquid
  assign banner_height = section.settings.banner_height

  case banner_height
    when '500'
      assign banner_height_class = 'banner-height-500'
    when '650'
      assign banner_height_class = 'banner-height-650'
    when '800'
      assign banner_height_class = 'banner-height-800'
    when '100vh'
      assign banner_height_class = 'banner-height-full'
    else
      assign banner_height_class = 'banner-height-fit'
  endcase
%}

<section
  class="custom-banner-section {{ banner_height_class }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="{% if section.settings.section_width == 'page' %}page-width{% endif %}">
    
    {% if section.settings.banner_link != blank %}
      <a
        href="{{ section.settings.banner_link }}"
        class="custom-banner-link"
        aria-label="Banner Link"
      >
    {% endif %}

    <div class="custom-banner">

      {% if section.settings.desktop_image != blank %}
        <picture>

          {% if section.settings.mobile_image != blank %}
            <source
              media="(max-width: 767px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 800 }}"
            >
          {% endif %}

          {{
            section.settings.desktop_image
            | image_url: width: 2400
            | image_tag:
              loading: 'lazy',
              widths: '550,750,1100,1500,1800,2400',
              class: 'custom-banner__image',
              alt: section.settings.desktop_image.alt
          }}

        </picture>
      {% else %}
        <div class="custom-banner__placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

    </div>

    {% if section.settings.banner_link != blank %}
      </a>
    {% endif %}

  </div>
</section>

{%  style %} 
.custom-banner-section {
  width: 100%;
}

.custom-banner {
  position: relative;
  overflow: hidden;
  width: 100%;
}

.custom-banner-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.custom-banner__image {
  width: 100%;
  display: block;
}

/* -----------------------------
   Fixed Height Options
--------------------------------*/
.banner-height-500 .custom-banner {
  height: 500px;
}

.banner-height-650 .custom-banner {
  height: 650px;
}

.banner-height-800 .custom-banner {
  height: 800px;
}

.banner-height-full .custom-banner {
  height: 100vh;
}

.banner-height-500 .custom-banner__image,
.banner-height-650 .custom-banner__image,
.banner-height-800 .custom-banner__image,
.banner-height-full .custom-banner__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* -----------------------------
   Fit To Image
--------------------------------*/
.banner-height-fit .custom-banner {
  height: auto;
}

.banner-height-fit .custom-banner__image {
  width: 100%;
  height: auto;
  object-fit: contain;
}

/* -----------------------------
   Placeholder
--------------------------------*/
.custom-banner__placeholder {
  background: #f5f5f5;
  min-height: 400px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-banner__placeholder svg {
  width: 120px;
  height: 120px;
  opacity: 0.3;
}

/* -----------------------------
   Page Width Support
--------------------------------*/
.page-width .custom-banner {
  border-radius: 0;
}

/* -----------------------------
   Mobile
--------------------------------*/
@media screen and (max-width: 767px) {
  .banner-height-500 .custom-banner {
    height: 300px;
  }

  .banner-height-650 .custom-banner {
    height: 400px;
  }

  .banner-height-800 .custom-banner {
    height: 500px;
  }

  .banner-height-full .custom-banner {
    height: 100vh;
  }

  .custom-banner__placeholder {
    min-height: 250px;
  }
}
{% endstyle %}


{% schema %}
{
  "name": "Custom Banner",
  "tag": "section",
  "class": "custom-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "default": "full",
      "options": [
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "page",
          "label": "Page Width"
        }
      ]
    },
    
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height",
      "default": "fit",
      "options": [
        {
          "value": "fit",
          "label": "Fit to Image"
        },
        {
          "value": "500",
          "label": "500px"
        },
        {
          "value": "650",
          "label": "650px"
        },
        {
          "value": "800",
          "label": "800px"
        },
        {
          "value": "100vh",
          "label": "Full Screen (100vh)"
        }
      ]
    },
    {
  "type": "url",
  "id": "banner_link",
  "label": "Banner Link"
},
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}