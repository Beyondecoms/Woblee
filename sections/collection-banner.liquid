{% comment %}
  Fully Customizable Hero Slideshow Section
{% endcomment %}

{%- liquid
  assign pos = section.settings.content_position | split: '-'
  assign y_pos = pos[0]
  assign x_pos = pos[1]

  if y_pos == 'top'
    assign align_items = 'flex-start'
  elsif y_pos == 'center'
    assign align_items = 'center'
  else
    assign align_items = 'flex-end'
  endif

  if x_pos == 'left'
    assign justify_content = 'flex-start'
  elsif x_pos == 'right'
    assign justify_content = 'flex-end'
  else
    assign justify_content = 'center'
  endif
-%}

{%- unless section.settings.heading_font.system? -%}
  <link rel="preload" as="font" href="{{ section.settings.heading_font | font_url }}" type="font/woff2" crossorigin>
{%- endunless -%}
{%- unless section.settings.body_font.system? -%}
  <link rel="preload" as="font" href="{{ section.settings.body_font | font_url }}" type="font/woff2" crossorigin>
{%- endunless -%}

<style>
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  #hero-slideshow-{{ section.id }} {
    --bg-color: {{ section.settings.section_bg }};
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --mt: {{ section.settings.margin_top }}px;
    --mb: {{ section.settings.margin_bottom }}px;
    --content-max-width: {{ section.settings.content_max_width }}px;

    --desktop-height: {{ section.settings.desktop_image_height }}px;
    --mobile-height: {{ section.settings.mobile_image_height }}px;

    --overlay-color-desktop: {{ section.settings.desktop_overlay_color }};
    --overlay-opacity-desktop: {{ section.settings.desktop_overlay_opacity | divided_by: 100.0 }};
    --overlay-color-mobile: {{ section.settings.mobile_overlay_color }};
    --overlay-opacity-mobile: {{ section.settings.mobile_overlay_opacity | divided_by: 100.0 }};

    --obj-pos-desktop: {{ section.settings.image_position_desktop }};
    --obj-pos-mobile: {{ section.settings.image_position_mobile }};

    --img-border-radius: {{ section.settings.image_border_radius }}px;
    --slide-border-radius: {{ section.settings.slide_border_radius }}px;

    --align-items: {{ align_items }};
    --justify-content: {{ justify_content }};
    --content-w-desktop: {{ section.settings.content_width_desktop }}px;
    --content-w-mobile: {{ section.settings.content_width_mobile }}px;

    --heading-font: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --heading-size: {{ section.settings.heading_size }}px;
    --heading-weight: {{ section.settings.heading_weight }};
    --heading-lh: {{ section.settings.heading_line_height }};
    --heading-ls: {{ section.settings.heading_letter_spacing }}px;
    --heading-color: {{ section.settings.heading_color }};
    --heading-hover-color: {{ section.settings.heading_hover_color }};
    --heading-transform: {{ section.settings.heading_transform }};

    --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --heading-lh-mobile: {{ section.settings.heading_line_height_mobile }};
    --heading-ls-mobile: {{ section.settings.heading_letter_spacing_mobile }}px;

    --body-font: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    --desc-size: {{ section.settings.desc_size }}px;
    --desc-weight: {{ section.settings.desc_weight }};
    --desc-lh: {{ section.settings.desc_line_height }};
    --desc-ls: {{ section.settings.desc_letter_spacing }}px;
    --desc-color: {{ section.settings.desc_color }};

    --desc-size-mobile: {{ section.settings.desc_size_mobile }}px;
    --desc-lh-mobile: {{ section.settings.desc_line_height_mobile }};

    --btn1-bg: {{ section.settings.btn1_bg }};
    --btn1-text: {{ section.settings.btn1_text }};
    --btn1-border: {{ section.settings.btn1_border_color }};
    --btn1-bw: {{ section.settings.btn1_border_width }}px;
    --btn1-br: {{ section.settings.btn1_border_radius }}px;
    --btn1-width: {{ section.settings.btn1_width }}px;
    --btn1-height: {{ section.settings.btn1_height }}px;
    --btn1-px: {{ section.settings.btn1_padding_x }}px;
    --btn1-py: {{ section.settings.btn1_padding_y }}px;
    --btn1-size: {{ section.settings.btn1_size }}px;
    --btn1-size-mobile: 10px;
    --btn1-weight: {{ section.settings.btn1_weight }};
    --btn1-ls: {{ section.settings.btn1_letter_spacing }}px;
    --btn1-hover-bg: {{ section.settings.btn1_hover_bg }};
    --btn1-hover-text: {{ section.settings.btn1_hover_text }};
    --btn1-hover-border: {{ section.settings.btn1_hover_border }};

    --btn2-bg: {{ section.settings.btn2_bg }};
    --btn2-text: {{ section.settings.btn2_text }};
    --btn2-border: {{ section.settings.btn2_border_color }};
    --btn2-bw: {{ section.settings.btn2_border_width }}px;
    --btn2-br: {{ section.settings.btn2_border_radius }}px;
    --btn2-width: {{ section.settings.btn2_width }}px;
    --btn2-height: {{ section.settings.btn2_height }}px;
    --btn2-px: {{ section.settings.btn2_padding_x }}px;
    --btn2-py: {{ section.settings.btn2_padding_y }}px;
    --btn2-size: {{ section.settings.btn2_size }}px;
    --btn2-size-mobile: 10px;
    --btn2-weight: {{ section.settings.btn2_weight }};
    --btn2-ls: {{ section.settings.btn2_letter_spacing }}px;
    --btn2-hover-bg: {{ section.settings.btn2_hover_bg }};
    --btn2-hover-text: {{ section.settings.btn2_hover_text }};
    --btn2-hover-border: {{ section.settings.btn2_hover_border }};

    --btn1-width-mobile: {{ section.settings.btn1_width_mobile }}px;
    --btn1-height-mobile: {{ section.settings.btn1_height_mobile }}px;
    --btn2-width-mobile: {{ section.settings.btn2_width_mobile }}px;
    --btn2-height-mobile: {{ section.settings.btn2_height_mobile }}px;

    --arrow-color: {{ section.settings.arrow_color }};
    --arrow-hover-color: {{ section.settings.arrow_hover_color }};
    --arrow-bg: {{ section.settings.arrow_bg }};
    --arrow-hover-bg: {{ section.settings.arrow_hover_bg }};
    --arrow-size: {{ section.settings.arrow_size }}px;
    --arrow-size-mobile: {{ section.settings.arrow_size_mobile }}px;
    --arrow-br: {{ section.settings.arrow_border_radius }}px;

    --dot-color: {{ section.settings.dot_color }};
    --dot-active-color: {{ section.settings.dot_active_color }};
    --dot-width: {{ section.settings.dot_width }}px;
    --dot-height: {{ section.settings.dot_height }}px;
    --dot-active-width: {{ section.settings.dot_active_width }}px;
    --dot-br: {{ section.settings.dot_border_radius }}px;
    --dot-gap: {{ section.settings.dot_gap }}px;

    --transition-duration: {{ section.settings.transition_duration }}s;
  }

  .hero-slideshow {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--bg-color);
    padding-top: var(--pt-desktop);
    padding-bottom: var(--pb-desktop);
    margin-top: var(--mt);
    margin-bottom: var(--mb);
  }

  .hero-slideshow__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-slideshow__track {
    display: flex;
    transition: transform var(--transition-duration) cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  .hero-slideshow__slide {
    position: relative;
    min-width: 100%;
    width: 100%;
    border-radius: var(--slide-border-radius);
    overflow: hidden;
  }

  .hero-slideshow__media {
    position: relative;
    width: 100%;
    height: var(--desktop-height);
    border-radius: var(--img-border-radius);
    overflow: hidden;
  }

  .hero-slideshow__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--obj-pos-desktop);
    display: block;
  }

  .hero-slideshow__overlay {
    position: absolute;
    inset: 0;
    background: var(--block-overlay-color, var(--overlay-color-desktop));
    opacity: var(--block-overlay-opacity, var(--overlay-opacity-desktop));
    pointer-events: none;
  }

  .hero-slideshow__overlay-content {
    position: absolute;
    inset: 0;
    display: flex;
    padding: 3.5%;
    align-items: var(--align-items);
    justify-content: var(--justify-content);
    pointer-events: none;
  }

  .hero-slideshow__content {
    pointer-events: auto;
    max-width: var(--content-w-desktop);
    text-align: var(--block-text-align, left);
    display: flex;
    flex-direction: column;
    z-index: 2;
  }

  .hero-slideshow__heading {
    font-family: var(--heading-font);
    font-size: var(--heading-size);
    font-weight: var(--heading-weight);
    line-height: var(--heading-lh);
    letter-spacing: var(--heading-ls);
    color: var(--block-heading-color, var(--heading-color));
    text-transform: uppercase;
    margin: 0 0 10px;
    transition: color 0.3s ease;
  }
  .hero-slideshow__heading:hover {
    color: var(--heading-hover-color);
  }
  
  .hero-slideshow__subtext {
    font-family: var(--body-font);
    font-size: var(--desc-size);
    font-weight: var(--desc-weight);
    line-height: var(--desc-lh);
    letter-spacing: var(--desc-ls);
    color: var(--block-desc-color, var(--desc-color));
    margin: 0;
  }

  .hero-slideshow__cta-group {
    display: flex;
    gap: 10px;
    justify-content: var(--block-btn-align, flex-start);
    margin-top: 15px;
    z-index: 2;
  }

  .hero-slideshow__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
    white-space: nowrap;
  }

  .hero-slideshow__btn--1 {
    background: var(--block-btn1-bg, var(--btn1-bg));
    color: var(--block-btn1-text, var(--btn1-text));
    border: var(--btn1-bw) solid var(--btn1-border);
    border-radius: var(--btn1-br);
    width: var(--btn1-width);
    min-width: var(--btn1-width);
    height: var(--btn1-height);
    min-height: var(--btn1-height);
    padding: var(--btn1-py) var(--btn1-px);
    font-size: var(--btn1-size);
    font-weight: var(--btn1-weight);
    letter-spacing: var(--btn1-ls);
    box-sizing: border-box;
  }
  .hero-slideshow__btn--1:hover {
    background: var(--btn1-hover-bg);
    color: var(--btn1-hover-text);
    border-color: var(--btn1-hover-border);
  }

  .hero-slideshow__btn--2 {
    background: var(--block-btn2-bg, var(--btn2-bg));
    color: var(--block-btn2-text, var(--btn2-text));
    border: var(--btn2-bw) solid var(--btn2-border);
    border-radius: var(--btn2-br);
    width: var(--btn2-width);
    min-width: var(--btn2-width);
    height: var(--btn2-height);
    min-height: var(--btn2-height);
    padding: var(--btn2-py) var(--btn2-px);
    font-size: var(--btn2-size);
    font-weight: var(--btn2-weight);
    letter-spacing: var(--btn2-ls);
    box-sizing: border-box;
  }
  .hero-slideshow__btn--2:hover {
    background: var(--btn2-hover-bg);
    color: var(--btn2-hover-text);
    border-color: var(--btn2-hover-border);
  }

  .hero-slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: var(--arrow-bg);
    color: var(--arrow-color);
    border: none;
    cursor: pointer;
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    width: var(--arrow-size);
    height: var(--arrow-size);
    border-radius: var(--arrow-br);
  }

  .hero-slideshow__arrow:hover {
    background: var(--arrow-hover-bg);
    color: var(--arrow-hover-color);
  }

  .hero-slideshow__arrow svg {
    width: 50%;
    height: 50%;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hero-slideshow__arrow--prev { left: 2%; }
  .hero-slideshow__arrow--next { right: 2%; }

  .hero-slideshow__dots {
    position: absolute;
    bottom: 5%;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: var(--dot-gap);
    z-index: 10;
  }

  .hero-slideshow__dot {
    width: var(--dot-width);
    height: var(--dot-height);
    background: var(--dot-color);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, width 0.25s ease;
    border-radius: var(--dot-br);
  }

  .hero-slideshow__dot--active {
    background: var(--dot-active-color);
    width: var(--dot-active-width);
  }

  /* Mobile Adjustments */
  @media (max-width: 767px) {
    .hero-slideshow {
      padding-top: var(--pt-mobile);
      padding-bottom: var(--pb-mobile);
    }
    .hero-slideshow__media {
      height: var(--mobile-height);
    }
    .hero-slideshow__img {
      object-position: var(--obj-pos-mobile);
    }
    .hero-slideshow__overlay {
      background: var(--block-overlay-color-mobile, var(--overlay-color-mobile));
      opacity: var(--block-overlay-opacity-mobile, var(--overlay-opacity-mobile));
    }
    .hero-slideshow__content {
      max-width: var(--content-w-mobile);
    }
    .hero-slideshow__heading {
      font-size: var(--heading-size-mobile);
      line-height: var(--heading-lh-mobile);
      letter-spacing: var(--heading-ls-mobile);
    }
    .hero-slideshow__subtext {
      font-size: var(--desc-size-mobile);
      line-height: var(--desc-lh-mobile);
    }
    .hero-slideshow__arrow {
      width: var(--arrow-size-mobile);
      height: var(--arrow-size-mobile);
    }
    .hero-slideshow__btn--1 {
      width: var(--btn1-width-mobile);
      min-width: var(--btn1-width-mobile);
      height: var(--btn1-height-mobile);
      min-height: var(--btn1-height-mobile);
      font-size: var(--btn1-size-mobile);
    }
    .hero-slideshow__btn--2 {
      width: var(--btn2-width-mobile);
      min-width: var(--btn2-width-mobile);
      height: var(--btn2-height-mobile);
      min-height: var(--btn2-height-mobile);
      font-size: var(--btn2-size-mobile);
    }
  }
</style>

{%- assign slide_count = section.blocks | size -%}

<section
  class="hero-slideshow"
  id="hero-slideshow-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-pause-on-hover="{{ section.settings.pause_on_hover }}"
  data-infinite="{{ section.settings.infinite_loop }}"
  aria-label="Hero slideshow"
>
  <div class="hero-slideshow__inner">
    <div class="hero-slideshow__track" id="hsTrack-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <div
          class="hero-slideshow__slide"
          id="slide-{{ block.id }}"
          role="group"
          aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
          style="
            {% if b.override_colors %}
              --block-heading-color: {{ b.heading_color }};
              --block-desc-color: {{ b.desc_color }};
              --block-btn1-bg: {{ b.btn1_bg }};
              --block-btn1-text: {{ b.btn1_text }};
              --block-btn2-bg: {{ b.btn2_bg }};
              --block-btn2-text: {{ b.btn2_text }};
            {% endif %}
            {% if b.override_overlay %}
              --block-overlay-color: {{ b.overlay_color }};
              --block-overlay-opacity: {{ b.overlay_opacity | divided_by: 100.0 }};
              --block-overlay-color-mobile: {{ b.overlay_color }};
              --block-overlay-opacity-mobile: {{ b.overlay_opacity | divided_by: 100.0 }};
            {% endif %}
            {% if b.override_alignment %}
              --block-text-align: {{ b.text_alignment }};
              --block-btn-align: {{ b.button_alignment }};
            {% endif %}
          "
          {{ block.shopify_attributes }}
        >
          <div class="hero-slideshow__media">
            {%- if b.image != blank -%}
              <picture>
                {%- if b.mobile_image != blank -%}
                  <source
                    media="(max-width: 767px)"
                    srcset="{{ b.mobile_image | image_url: width: 800 }}"
                  >
                {%- endif -%}
                <img
                  class="hero-slideshow__img"
                  src="{{ b.image | image_url: width: 2000 }}"
                  srcset="
                    {{ b.image | image_url: width: 800 }} 800w,
                    {{ b.image | image_url: width: 1200 }} 1200w,
                    {{ b.image | image_url: width: 1600 }} 1600w,
                    {{ b.image | image_url: width: 2000 }} 2000w
                  "
                  sizes="100vw"
                  alt="{{ b.image.alt | escape | default: b.heading }}"
                  {%- if forloop.first -%}loading="eager" fetchpriority="high"{%- else -%}loading="lazy"{%- endif -%}
                  width="{{ b.image.width }}"
                  height="{{ b.image.height }}"
                >
              </picture>
            {%- else -%}
              <div class="hero-slideshow__img" style="background:#1a1a1a;"></div>
            {%- endif -%}

            <div class="hero-slideshow__overlay"></div>

            <div class="hero-slideshow__overlay-content">
              <div class="hero-slideshow__content">
                {%- if b.heading != blank -%}
                  <p class="hero-slideshow__heading">{{ b.heading }}</p>
                {%- endif -%}
                {%- if b.subtext != blank -%}
                  <p class="hero-slideshow__subtext">{{ b.subtext }}</p>
                {%- endif -%}
                
                {%- if b.button_1_label != blank or b.button_2_label != blank -%}
                  <div class="hero-slideshow__cta-group">
                    {%- if b.button_1_label != blank -%}
                      <a
                        href="{{ b.button_1_link | default: '#' }}"
                        class="hero-slideshow__btn hero-slideshow__btn--1"
                      >{{ b.button_1_label }}</a>
                    {%- endif -%}
                    {%- if b.button_2_label != blank -%}
                      <a
                        href="{{ b.button_2_link | default: '#' }}"
                        class="hero-slideshow__btn hero-slideshow__btn--2"
                      >{{ b.button_2_label }}</a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>

          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if slide_count > 1 -%}
      <button
        class="hero-slideshow__arrow hero-slideshow__arrow--prev"
        aria-label="Previous slide"
        id="hsPrev-{{ section.id }}"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="hero-slideshow__arrow hero-slideshow__arrow--next"
        aria-label="Next slide"
        id="hsNext-{{ section.id }}"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <div
        class="hero-slideshow__dots"
        role="tablist"
        aria-label="Slideshow navigation"
        id="hsDots-{{ section.id }}"
      >
        {%- for block in section.blocks -%}
          <button
            class="hero-slideshow__dot{% if forloop.first %} hero-slideshow__dot--active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function () {
  var sectionId   = '{{ section.id }}';
  var root        = document.getElementById('hero-slideshow-' + sectionId);
  if (!root) return;

  var track       = document.getElementById('hsTrack-' + sectionId);
  var prevBtn     = document.getElementById('hsPrev-' + sectionId);
  var nextBtn     = document.getElementById('hsNext-' + sectionId);
  var dotsWrap    = document.getElementById('hsDots-' + sectionId);
  if (!track) return;

  var total       = track.children.length;
  var current     = 0;
  var autoplay    = root.dataset.autoplay === 'true';
  var speed       = parseInt(root.dataset.autoplaySpeed, 10) || 5000;
  var pauseHover  = root.dataset.pauseOnHover === 'true';
  var infinite    = root.dataset.infinite === 'true';
  var timer       = null;
  var isHovered   = false;
  var dots        = dotsWrap ? dotsWrap.querySelectorAll('.hero-slideshow__dot') : [];

  function updateArrows() {
    if (!infinite && total > 1) {
      if (prevBtn) prevBtn.disabled = (current === 0);
      if (nextBtn) nextBtn.disabled = (current === total - 1);
      if (prevBtn) prevBtn.style.opacity = (current === 0) ? '0.3' : '';
      if (nextBtn) nextBtn.style.opacity = (current === total - 1) ? '0.3' : '';
      if (prevBtn) prevBtn.style.cursor = (current === 0) ? 'not-allowed' : 'pointer';
      if (nextBtn) nextBtn.style.cursor = (current === total - 1) ? 'not-allowed' : 'pointer';
    }
  }

  function goTo(index) {
    if (!infinite) {
      if (index < 0) index = 0;
      if (index >= total) index = total - 1;
    } else {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
    }
    
    current = index;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) {
      d.classList.toggle('hero-slideshow__dot--active', i === current);
      d.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
    updateArrows();
  }

  function startTimer() {
    if (!autoplay || total <= 1) return;
    clearInterval(timer);
    timer = setInterval(function () {
      if (pauseHover && isHovered) return;
      if (!infinite && current === total - 1) {
        clearInterval(timer);
        return;
      }
      goTo(current + 1);
    }, speed);
  }

  function resetTimer() { clearInterval(timer); startTimer(); }

  if (pauseHover) {
    root.addEventListener('mouseenter', function() { isHovered = true; });
    root.addEventListener('mouseleave', function() { isHovered = false; });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function () { 
      if (!infinite && current === 0) return;
      goTo(current - 1); 
      resetTimer(); 
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function () { 
      if (!infinite && current === total - 1) return;
      goTo(current + 1); 
      resetTimer(); 
    });
  }

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      goTo(parseInt(this.dataset.index, 10));
      resetTimer();
    });
  });

  /* Swipe / touch support */
  var touchStartX = 0;
  track.addEventListener('touchstart', function (e) {
    touchStartX = e.changedTouches[0].clientX;
  }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) {
      if (diff > 0 && (!infinite && current === total - 1)) return;
      if (diff < 0 && (!infinite && current === 0)) return;
      goTo(diff > 0 ? current + 1 : current - 1);
      resetTimer();
    }
  }, { passive: true });

  /* Keyboard */
  root.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { if (!infinite && current === 0) return; goTo(current - 1); resetTimer(); }
    if (e.key === 'ArrowRight') { if (!infinite && current === total - 1) return; goTo(current + 1); resetTimer(); }
  });

  updateArrows();
  startTimer();
})();
</script>

