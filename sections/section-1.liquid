            "card_label": "Pure Confidence"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_label": "Born Bold"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_label": "Fearless Spirit"
          }
        },
        {
