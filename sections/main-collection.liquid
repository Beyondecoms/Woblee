

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

{% style %}
  body.template-collection results-list[section-id='{{ section.id }}'] a.contents.user-select-text p {
    font-size: {{ section.settings.collection_card_title_font_size_desktop }}px;
    font-weight: {{ section.settings.collection_card_title_font_weight }};
    line-height: 1.3;
  }

  body.template-collection results-list[section-id='{{ section.id }}'] product-price .price {
    font-size: {{ section.settings.collection_card_price_font_size_desktop }}px;
    font-weight: {{ section.settings.collection_card_price_font_weight }};
    line-height: 1.3;
  }

  body.template-collection.modal-open .quick-add-modal__content .text-block h1,
  body.template-collection.modal-open .quick-add-modal__content .product-header a:not(product-price *) {
    font-size: {{ section.settings.quick_view_title_font_size_desktop }}px !important;
    font-weight: {{ section.settings.quick_view_title_font_weight }} !important;
    line-height: 1.2;
  }

  body.template-collection.modal-open .quick-add-modal__content product-price .price {
    font-size: {{ section.settings.quick_view_price_font_size_desktop }}px !important;
    font-weight: {{ section.settings.quick_view_price_font_weight }} !important;
    line-height: 1.3;
  }

  body.template-collection.modal-open .quick-add-modal__content :is(
      .variant-option legend,
      .variant-option__button-label__text,
      .details-content,
      .details-content p,
      .details-content li,
      .details-content span,
      .details-content strong,
      .quick-view__description-content,
      .quick-view__description-content p,
      .quick-view__description-content li
    ) {
    font-size: {{ section.settings.quick_view_content_font_size_desktop }}px !important;
  }

  body.template-collection.modal-open .quick-add-modal__content .details__header,
  body.template-collection.modal-open .quick-add-modal__content .details__header > * {
    font-size: {{ section.settings.quick_view_accordion_heading_font_size_desktop }}px !important;
    font-weight: {{ section.settings.quick_view_accordion_heading_font_weight }} !important;
  }

  body.template-collection.modal-open .quick-add-modal__content .add-to-cart-button {
    font-size: {{ section.settings.quick_view_add_to_cart_font_size_desktop }}px !important;
    font-weight: {{ section.settings.quick_view_add_to_cart_font_weight }} !important;
  }

  @media screen and (max-width: 749px) {
    body.template-collection results-list[section-id='{{ section.id }}'] a.contents.user-select-text p {
      font-size: {{ section.settings.collection_card_title_font_size_mobile }}px;
    }

    body.template-collection results-list[section-id='{{ section.id }}'] product-price .price {
      font-size: {{ section.settings.collection_card_price_font_size_mobile }}px;
    }

    body.template-collection.modal-open .quick-add-modal__content .text-block h1,
    body.template-collection.modal-open .quick-add-modal__content .product-header a:not(product-price *) {
      font-size: {{ section.settings.quick_view_title_font_size_mobile }}px !important;
    }

    body.template-collection.modal-open .quick-add-modal__content product-price .price {
      font-size: {{ section.settings.quick_view_price_font_size_mobile }}px !important;
    }

    body.template-collection.modal-open .quick-add-modal__content :is(
        .variant-option legend,
        .variant-option__button-label__text,
        .details-content,
        .details-content p,
        .details-content li,
        .details-content span,
        .details-content strong,
        .quick-view__description-content,
        .quick-view__description-content p,
        .quick-view__description-content li
      ) {
      font-size: {{ section.settings.quick_view_content_font_size_mobile }}px !important;
    }

    body.template-collection.modal-open .quick-add-modal__content .details__header,
    body.template-collection.modal-open .quick-add-modal__content .details__header > * {
      font-size: {{ section.settings.quick_view_accordion_heading_font_size_mobile }}px !important;
    }

    body.template-collection.modal-open .quick-add-modal__content .add-to-cart-button {
      font-size: {{ section.settings.quick_view_add_to_cart_font_size_mobile }}px !important;
    }
  }
{% endstyle %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in collection.products %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

