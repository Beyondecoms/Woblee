{% liquid
  assign section_id = 'timeline-tabs-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="timeline-tabs"
  style="
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  "
>
  <div class="timeline-tabs__inner page-width">

    {% if section.settings.heading != blank %}
      <div class="timeline-tabs__heading-wrap">
        <h2 class="timeline-tabs__heading">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}

      <div
        class="timeline-tabs__tabs"
        role="tablist"
        aria-label="{{ section.settings.heading | escape }}"
      >
        {% for block in section.blocks %}
          <button
            class="timeline-tabs__tab{% if forloop.first %} is-active{% endif %}"
            type="button"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="timeline-panel-{{ section.id }}-{{ forloop.index0 }}"
            id="timeline-tab-{{ section.id }}-{{ forloop.index0 }}"
            data-tab-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.year }}
          </button>
        {% endfor %}
      </div>

      <div class="timeline-tabs__panels">

        {% for block in section.blocks %}

          <div
            class="timeline-tabs__panel{% if forloop.first %} is-active{% endif %}"
            role="tabpanel"
            id="timeline-panel-{{ section.id }}-{{ forloop.index0 }}"
            aria-labelledby="timeline-tab-{{ section.id }}-{{ forloop.index0 }}"
            data-panel-index="{{ forloop.index0 }}"
            {% unless forloop.first %}
              hidden
            {% endunless %}
          >

            <div class="timeline-tabs__layout">

              <div class="timeline-tabs__image-wrap">

                {% if block.settings.image != blank %}

                  {{
                    block.settings.image
                    | image_url: width: 1800
                    | image_tag:
                      loading: 'lazy',
                      class: 'timeline-tabs__image',
                      alt: block.settings.title
                  }}

                {% else %}

                  <div class="timeline-tabs__image timeline-tabs__image--placeholder"></div>

                {% endif %}

              </div>

              <div class="timeline-tabs__content">

                {% if block.settings.title != blank %}
                  <h3 class="timeline-tabs__title">
                    {{ block.settings.title }}
                  </h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="timeline-tabs__text rte">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              </div>

            </div>

          </div>

        {% endfor %}

      </div>

    {% endif %}

  </div>
</section>


<style>
#{{ section_id }} {
  background: {{ section.settings.section_bg }};
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
}

#{{ section_id }} .timeline-tabs__inner {
  max-width: 1200px;
  margin: auto;
}

#{{ section_id }} .timeline-tabs__heading-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 15px;
}

#{{ section_id }} .timeline-tabs__heading {
  margin: 0;
  color: {{ section.settings.heading_color }};
  font-size: {{ section.settings.heading_size }}px;
  font-weight: 700;
  text-align: center;
  line-height: 1.1;
  text-transform: uppercase;
}

#{{ section_id }} .timeline-tabs__tabs {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 28px;
  margin-bottom: 30px;
  flex-wrap: wrap;
}

#{{ section_id }} .timeline-tabs__tab {
  border: none;
  background: transparent;
  cursor: pointer;
  color: {{ section.settings.tab_color }};
  font-size: {{ section.settings.tab_font_size }}px;
  font-weight: 600;
  padding: 8px 5px;
  position: relative;
  transition: all .3s ease;
}

#{{ section_id }} .timeline-tabs__tab:hover {
  color: {{ section.settings.tab_active_color }};
}

#{{ section_id }} .timeline-tabs__tab.is-active {
  color: {{ section.settings.tab_active_color }};
}

#{{ section_id }} .timeline-tabs__tab::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 3px;
  transform: translateX(-50%);
  background: {{ section.settings.tab_underline_color }};
  transition: all .3s ease;
}

#{{ section_id }} .timeline-tabs__tab.is-active::after {
  width: 35px;
}

#{{ section_id }} .timeline-tabs__panels {
  width: 100%;
}

#{{ section_id }} .timeline-tabs__panel {
  animation: timelineFade .4s ease;
}

@keyframes timelineFade {
  from {
    opacity: 0;
    transform: translateY(15px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

#{{ section_id }} .timeline-tabs__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: {{ section.settings.layout_gap }}px;
  align-items: center;
}

#{{ section_id }} .timeline-tabs__image-wrap {
  width: 100%;
}

#{{ section_id }} .timeline-tabs__image {
  width: 100%;
  height: {{ section.settings.image_height_desktop }}px;
  object-fit: {{ section.settings.image_fit }};
  border-radius: {{ section.settings.image_radius }}px;
  display: block;
}

#{{ section_id }} .timeline-tabs__image--placeholder {
  background: #f4f4f4;
  height: {{ section.settings.image_height_desktop }}px;
  border-radius: {{ section.settings.image_radius }}px;
}

#{{ section_id }} .timeline-tabs__content {
  max-width: {{ section.settings.content_width }}px;
}

#{{ section_id }} .timeline-tabs__title {
  margin: 0 0 20px;
  color: {{ section.settings.content_heading_color }};
  font-size: {{ section.settings.content_heading_size }}px;
  font-weight: 700;
  line-height: 1.2;
  text-transform: uppercase;
}

#{{ section_id }} .timeline-tabs__text {
  color: {{ section.settings.content_text_color }};
  font-size: {{ section.settings.content_text_size }}px;
  line-height: 1.8;
}

#{{ section_id }} .timeline-tabs__text p {
  margin: 0 0 18px;
}

#{{ section_id }} .timeline-tabs__text p:last-child {
  margin-bottom: 0;
}

/* Tablet */

@media screen and (max-width: 990px) {

  #{{ section_id }} .timeline-tabs__layout {
    grid-template-columns: 1fr;
    gap: 25px;
  }

  #{{ section_id }} .timeline-tabs__content {
    max-width: 90%;
    margin: auto;
  }

  #{{ section_id }} .timeline-tabs__image {
    height: {{ section.settings.image_height_mobile }}px;
  }

  #{{ section_id }} .timeline-tabs__image--placeholder {
    height: {{ section.settings.image_height_mobile }}px;
  }
}

/* Mobile */

@media screen and (max-width: 749px) {

  #{{ section_id }} .timeline-tabs__heading {
    font-size: calc({{ section.settings.heading_size }}px * 0.7);
  }

  #{{ section_id }} .timeline-tabs__tabs {
    flex-wrap: nowrap;
    overflow-x: auto;
    justify-content: center;
    gap: 20px;
    padding-bottom: 10px;
    scrollbar-width: none;
  }

  #{{ section_id }} .timeline-tabs__tabs::-webkit-scrollbar {
    display: none;
  }

  #{{ section_id }} .timeline-tabs__tab {
    flex: 0 0 auto;
  }

  #{{ section_id }} .timeline-tabs__image {
    height: {{ section.settings.image_height_mobile }}px;
  }

  #{{ section_id }} .timeline-tabs__image--placeholder {
    height: {{ section.settings.image_height_mobile }}px;
  }

  #{{ section_id }} .timeline-tabs__title {
    font-size: calc({{ section.settings.content_heading_size }}px * 0.8);
  }

  #{{ section_id }} .timeline-tabs__text {
    font-size: calc({{ section.settings.content_text_size }}px * 0.9);
  }
}
</style>

<script>
  (function () {
    const sectionId = "{{ section.id }}";
    const root = document.getElementById(`timeline-tabs-${sectionId}`);
    if (!root) return;

    const tabs = Array.from(root.querySelectorAll('.timeline-tabs__tab'));
    const panels = Array.from(root.querySelectorAll('.timeline-tabs__panel'));

    function activateTab(index) {
      tabs.forEach((tab, i) => {
        const active = i === index;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach((panel, i) => {
        const active = i === index;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(index));
    });
  })();
</script>

{% schema %}
{
  "name": "Timeline tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About us"
